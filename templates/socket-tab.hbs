<section class="sockets tab sc-sockets-tab sc-sockets-view {{socketTabLayoutClass}} {{tab.cssClass}}" data-tab="{{tab.id}}"
  data-group="{{tab.group}}" data-application-part="{{partId}}" data-sc-sockets-layout="{{socketTabVariant}}">

  <section class="items-list sockets-list sc-sockets-list" data-item-list="sockets">
    <section class="items-section card sc-sockets-panel sc-sockets-main-section" data-socket-type="default">

      <div class="items-header header sc-sockets-header">
        <h3 class="item-name socket-name">{{ localize "SCSockets.TabLabel" }}</h3>
        <div class="item-header socket-source">{{ localize "SCSockets.ColumnSlot" }}</div>
        <div class="item-header item-controls socket-controls">
          {{#if canAddSocketSlot}}
          <a class="socket-control item-control always-interactive" data-action="addSocketSlot" data-tooltip
            aria-label="{{ localize 'SCSockets.ActionAdd' }}">
            <i class="fas fa-plus"></i> {{ localize "SCSockets.ActionAdd" }}
          </a>
          {{/if}}
        </div>
      </div>

      {{#if sockets.length}}
        {{#if useSocketGridLayout}}
        <ol class="item-list unlist sc-sockets-collection">
          {{#each sockets as |slot|}}
          <li class="item socket-row sc-sockets-slot-card sc-sockets-slot-card--icon-only" data-index="{{slot.index}}" data-item-uuid="{{slot.hostItemUuid}}" data-dropzone="socket-slot"
            aria-dropeffect="copy">

            <div class="item-name socket-name sc-sockets-slot-main">
              <div class="sc-sockets-slot-visual {{#if slot.hasSlotTint}}has-slot-tint{{/if}}" aria-label="{{slot.slotAriaLabel}}" {{#if slot.hasSlotTint}}style="{{slot.slotMaskStyle}}"{{/if}}>
                <img class="item-image socket-icon sc-sockets-slot-frame {{#if slot.hasSlotTint}}is-tinted{{/if}}" src="{{slot.slotFrameImg}}" alt="{{slot.slotAriaLabel}}">
                {{#if slot.hasGem}}
                <img class="item-image socket-icon sc-sockets-slot-gem" src="{{slot.gemImg}}" alt="{{slot.gemName}}">
                {{/if}}
                {{#if ../canConfigureSlots}}
                <a class="sc-sockets-slot-edit-hit" data-action="openSocketSlotConfig" data-index="{{slot.index}}"
                  draggable="false" aria-label="{{ localize 'SCSockets.Tooltips.ConfigureSlotLabel' }}"
                  data-tooltip="{{ localize 'SCSockets.Tooltips.ConfigureSlot' }}"
                  data-tooltip-direction="LEFT">
                  <span class="sc-sockets-slot-edit-badge">
                    <i class="fas fa-pen"></i>
                  </span>
                </a>
                {{/if}}
              </div>
            </div>

            <div class="item-detail item-controls socket-controls sc-sockets-slot-actions">
              {{#if ../canToggleSlotVisibility}}
              <a class="socket-control item-control sc-sockets-slot-action sc-sockets-slot-action--visibility"
                data-action="toggleSocketSlotVisibility" data-index="{{slot.index}}"
                aria-label="{{slot.visibilityLabel}}"
                data-tooltip="{{slot.visibilityTooltip}}"
                data-tooltip-direction="LEFT">
                <i class="fas {{slot.visibilityIcon}}"></i>
              </a>
              {{/if}}
              {{#if slot.hasGem}}
                {{#if ../editable}}
                <a class="socket-control item-control sc-sockets-slot-action sc-sockets-slot-action--remove-gem"
                  data-action="removeGemFromSlot" data-index="{{slot.index}}"
                  aria-label="{{slot.removeGemTooltip}}"
                  data-tooltip="{{slot.removeGemTooltip}}"
                  data-tooltip-direction="LEFT">
                  <i class="fas {{slot.removeGemIcon}}"></i>
                </a>
                {{/if}}
              {{/if}}
              {{#if ../canManageSockets}}
              <a class="socket-control item-control sc-sockets-slot-action sc-sockets-slot-action--remove-slot"
                data-action="removeSocketSlot" data-index="{{slot.index}}" data-tooltip
                aria-label="{{ localize 'SCSockets.Tooltips.DeleteSlotLabel' }}"
                data-tooltip="{{ localize 'SCSockets.Tooltips.DeleteSocket' }}"
                data-tooltip-direction="LEFT">
                <i class="fas fa-circle-xmark"></i>
              </a>
              {{/if}}
            </div>
          </li>
          {{/each}}
        </ol>
        {{else}}
        <ol class="item-list unlist">
          {{#each sockets as |slot|}}
          <li class="item flexrow socket-row" data-index="{{slot.index}}" data-item-uuid="{{slot.hostItemUuid}}" data-dropzone="socket-slot" aria-dropeffect="copy">

            <div class="item-name socket-name sc-sockets-slot-main">
              <div class="socket-icon-wrapper sc-sockets-slot-visual {{#if slot.hasSlotTint}}has-slot-tint{{/if}}" aria-label="{{slot.slotAriaLabel}}" {{#if slot.hasSlotTint}}style="{{slot.slotMaskStyle}}"{{/if}}>
                <img class="item-image socket-icon sc-sockets-slot-frame {{#if slot.hasSlotTint}}is-tinted{{/if}}" src="{{slot.slotFrameImg}}" alt="{{slot.slotAriaLabel}}">
                {{#if slot.hasGem}}
                <img class="item-image socket-icon sc-sockets-slot-gem" src="{{slot.gemImg}}" alt="{{slot.gemName}}">
                {{/if}}
                {{#if ../canConfigureSlots}}
                <a class="sc-sockets-slot-edit-hit" data-action="openSocketSlotConfig" data-index="{{slot.index}}"
                  draggable="false" aria-label="{{ localize 'SCSockets.Tooltips.ConfigureSlotLabel' }}"
                  data-tooltip="{{ localize 'SCSockets.Tooltips.ConfigureSlot' }}"
                  data-tooltip-direction="LEFT">
                  <span class="sc-sockets-slot-edit-badge">
                    <i class="fas fa-pen"></i>
                  </span>
                </a>
                {{/if}}
              </div>
              <div class="name name-stacked">
                <span class="title">{{slot.slotName}}</span>
              </div>
            </div>

            <div class="item-detail socket-source {{#unless slot.gem}}empty{{/unless}}">
              {{#if slot.gem}}
              {{slot.gem.name}}
              {{else}}
              &ndash;
              {{/if}}
            </div>

            <div class="item-detail item-controls socket-controls">
              {{#if ../canToggleSlotVisibility}}
              <a class="socket-control item-control" data-action="toggleSocketSlotVisibility" data-index="{{slot.index}}"
                aria-label="{{slot.visibilityLabel}}"
                data-tooltip="{{slot.visibilityTooltip}}"
                data-tooltip-direction="LEFT">
                <i class="fas {{slot.visibilityIcon}}"></i>
              </a>
              {{/if}}
              {{#if ../canConfigureSlots}}
              <a class="socket-control item-control" data-action="openSocketSlotConfig" data-index="{{slot.index}}"
                aria-label="{{ localize 'SCSockets.Tooltips.ConfigureSlotLabel' }}"
                data-tooltip="{{ localize 'SCSockets.Tooltips.ConfigureSlot' }}"
                data-tooltip-direction="LEFT">
                <i class="fas fa-pen-to-square"></i>
              </a>
              {{/if}}
              {{#if ../editable}}
              <a class="socket-control item-control" data-action="removeGemFromSlot" data-index="{{slot.index}}"
                aria-label="{{slot.removeGemTooltip}}"
                data-tooltip="{{slot.removeGemTooltip}}"
                data-tooltip-direction="LEFT">
                <i class="fas {{slot.removeGemIcon}}"></i>
              </a>
              {{/if}}
              {{#if ../canManageSockets}}
              <a class="socket-control item-control" data-action="removeSocketSlot" data-index="{{slot.index}}" data-tooltip
                aria-label="{{ localize 'SCSockets.Tooltips.DeleteSlotLabel' }}"
                data-tooltip="{{ localize 'SCSockets.Tooltips.DeleteSocket' }}"
                data-tooltip-direction="LEFT">
                <i class="fas fa-trash"></i>
              </a>
              {{/if}}
            </div>
          </li>
          {{/each}}
        </ol>
        {{/if}}
      {{else}}
      <ol class="item-list unlist sc-sockets-collection">
        <li class="notification info sc-sockets-empty-state" data-dropzone="socket-slot" aria-dropeffect="copy">
          {{ localize "SCSockets.EmptyList" }}
        </li>
      </ol>
      {{/if}}

    </section>

    {{#if hasSocketResourceRows}}
    <section class="items-section card sc-sockets-panel sc-sockets-resource-section"
             data-sc-sockets="socket-resource-table">
      <div class="items-header header sc-sockets-resource-header">
        <h3 class="item-name sc-sockets-resource-name-col">
          {{ localize "SCSockets.SocketPools.GemColumn" }}
        </h3>
        <div class="item-header sc-sockets-resource-id-col">{{ localize "SCSockets.SocketPools.ResourceColumn" }}</div>
        <div class="item-header sc-sockets-resource-charges-col">{{ localize "SCSockets.SocketPools.ChargesColumn" }}</div>
        <div class="item-header sc-sockets-resource-destroy-col">{{ localize "SCSockets.SocketPools.DestroyColumn" }}</div>
      </div>
      <ol class="item-list unlist sc-sockets-resource-rows">
        {{#each socketResourceRows as |row|}}
        <li class="item flexrow sc-sockets-resource-row">
          <div class="item-name sc-sockets-resource-name-col">
            {{#if row.gemImg}}
            <img class="item-image"
                 src="{{row.gemImg}}"
                 alt="{{row.gemName}}"
                 aria-label="{{row.gemName}}"
                 data-tooltip="{{row.gemName}}"
                 data-tooltip-direction="UP">
            {{else}}
            <div class="item-image sc-sockets-resource-image-fallback"
                 aria-label="{{row.gemName}}"
                 data-tooltip="{{row.gemName}}"
                 data-tooltip-direction="UP">
              <i class="fa-solid fa-gem"></i>
            </div>
            {{/if}}
          </div>
          <div class="item-detail sc-sockets-resource-id-col">{{row.resourceKey}}</div>
          <div class="item-detail sc-sockets-resource-charges-col">{{row.chargesLabel}}</div>
          <div class="item-detail sc-sockets-resource-destroy-col">
            <span class="sc-sockets-resource-destroy-badge {{#if row.destroyOnEmpty}}is-destroy-on-empty{{else}}is-keep-on-empty{{/if}}">
              {{row.destroyAtZeroLabel}}
            </span>
          </div>
        </li>
        {{/each}}
      </ol>
    </section>
    {{/if}}
  </section>
</section>

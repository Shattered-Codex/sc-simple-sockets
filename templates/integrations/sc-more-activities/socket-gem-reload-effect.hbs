<section class="tab activity-{{ tab.id }} {{ tab.cssClass }} sc-sockets-scma-activity sc-sockets-scma-effect sc-sockets-scma-effect--gem-reload" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
  {{#if appliedEffects}}{{> "systems/dnd5e/templates/activity/parts/activity-effects.hbs" }}{{/if}}

  <fieldset class="sc-sockets-scma-fieldset sc-sockets-scma-fieldset--configuration">
    <legend>{{ localize "SCSockets.Integrations.ScMoreActivities.GemReload.Sections.Configuration" }}</legend>
    <p class="hint">{{ targetingHint }}</p>

    <div class="form-group">
      <label>{{ localize "SCSockets.Integrations.ScMoreActivities.GemReload.Fields.TargetMode.Label" }}</label>
      <div class="form-fields">
        <select name="reload.targetMode">
          {{ selectOptions targetModeOptions selected=reload.targetMode valueAttr="value" labelAttr="label" }}
        </select>
      </div>
      <p class="hint">{{ localize "SCSockets.Integrations.ScMoreActivities.GemReload.Fields.TargetMode.Hint" }}</p>
    </div>

    <div class="form-group">
      <label>{{ localize "SCSockets.Integrations.ScMoreActivities.GemReload.Fields.GemMode.Label" }}</label>
      <div class="form-fields">
        <select name="reload.gemMode">
          {{ selectOptions gemModeOptions selected=reload.gemMode valueAttr="value" labelAttr="label" }}
        </select>
      </div>
      <p class="hint">{{ localize "SCSockets.Integrations.ScMoreActivities.GemReload.Fields.GemMode.Hint" }}</p>
    </div>

    {{#if needsGemQuery}}
    <div class="form-group">
      <label>{{ localize "SCSockets.Integrations.ScMoreActivities.GemReload.Fields.GemQuery.Label" }}</label>
      <div class="form-fields">
        <input type="text" name="reload.gemQuery" value="{{ reload.gemQuery }}" placeholder="{{ gemQueryPlaceholder }}">
      </div>
      <p class="hint">{{ gemQueryHint }}</p>
    </div>
    {{/if}}

    <div class="form-group">
      <label>{{ localize "SCSockets.Integrations.ScMoreActivities.GemReload.Fields.SlotMode.Label" }}</label>
      <div class="form-fields">
        <select name="reload.slotMode">
          {{ selectOptions slotModeOptions selected=reload.slotMode valueAttr="value" labelAttr="label" }}
        </select>
      </div>
      <p class="hint">{{ localize "SCSockets.Integrations.ScMoreActivities.GemReload.Fields.SlotMode.Hint" }}</p>
    </div>

    {{#unless isSelfTarget}}
    <div class="form-group sc-sockets-scma-cursor-image-field">
      <label>{{ localize "SCSockets.Integrations.ScMoreActivities.Common.CursorImage.Label" }}</label>
      <div class="form-fields">
        <file-picker
          name="reload.cursorImage"
          type="image"
          value="{{ reload.cursorImage }}"
          placeholder="{{ localize "SCSockets.Integrations.ScMoreActivities.Common.CursorImage.Placeholder" }}"
        ></file-picker>
      </div>
      <p class="hint">{{ localize "SCSockets.Integrations.ScMoreActivities.Common.CursorImage.Hint" }}</p>
    </div>
    {{/unless}}
  </fieldset>
</section>
